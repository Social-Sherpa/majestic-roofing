---
import { Image } from 'astro:assets';

interface Props {
  logo: ImageMetadata;
  logoAlt: string;
  reviewBadge?: ImageMetadata;
  reviewBadgeAlt?: string;
  reviewScore?: string;
  reviewCount?: string;
  checkatradeLogo?: ImageMetadata;
  checkatradeScore?: string;
  checkatradeCount?: string;
  phone?: string;
  phoneLabel?: string;
}

const {
  logo,
  logoAlt,
  reviewBadge,
  reviewBadgeAlt = 'Review platform logos',
  reviewScore = 'Rated 4.9 Based On',
  reviewCount = '97+ Verified Reviews',
  checkatradeLogo,
  checkatradeScore = 'Rated 10/10',
  checkatradeCount = '40+ Reviews',
  phone = '01225 985713',
  phoneLabel = 'Call Us For a Free Quote',
} = Astro.props;

const phoneHref = `tel:${phone.replace(/\s/g, '')}`;
---

<header class="header">
  <div class="header__inner">
    <a class="header__logo" href="#">
      <Image src={logo} alt={logoAlt} width={376} quality={100} format="png" loading="eager" />
    </a>

    <div class="header__right">
      <div class="header__badges">
        {reviewBadge && (
          <div class="header__badge header__badge--reviews">
            <Image src={reviewBadge} alt={reviewBadgeAlt} width={400} quality={100} loading="eager" />
            <div class="header__badge-text">
              <span class="header__badge-score"><strong>{reviewScore}</strong></span>
              <span class="header__badge-detail">{reviewCount}</span>
            </div>
          </div>
        )}

        {reviewBadge && checkatradeLogo && (
          <div class="header__badge-divider"></div>
        )}

        {checkatradeLogo && (
          <div class="header__badge header__badge--checkatrade">
            <Image src={checkatradeLogo} alt="Checkatrade approved roofer" width={400} quality={100} format="png" loading="eager" />
            <div class="header__badge-text">
              <span class="header__badge-score"><strong>{checkatradeScore}</strong> ({checkatradeCount})</span>
            </div>
          </div>
        )}
      </div>

      <div class="header__phone">
        <div>
          <div class="header__phone-number"><a href={phoneHref}>{phone}</a></div>
          <div class="header__phone-label">{phoneLabel}</div>
        </div>
      </div>
    </div>
  </div>
</header>
