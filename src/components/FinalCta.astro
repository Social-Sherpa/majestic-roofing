---
import { Image } from 'astro:assets';
import bgImg from '../assets/images/hero-roofer-inspecting-slate-roof-north-london.webp';

interface Props {
  phone?: string;
}

const { phone = '01225 985713' } = Astro.props;
const phoneHref = `tel:${phone.replace(/\s/g, '')}`;
---

<section class="final-cta" id="contact">
  <Image src={bgImg} alt="" class="final-cta__bg" widths={[800, 1200, 1600]} loading="lazy" />
  <div class="final-cta__overlay"></div>
  <div class="container final-cta__content">
    <h2>Ready to Fix Your Roof?</h2>
    <p class="final-cta__subtitle">Get a free, no-obligation quote from a team that's been trusted across Bath for over 20 years.</p>
    <div class="final-cta__phone"><a href={phoneHref}>{phone}</a></div>
    <div class="final-cta__row">
      <a href={phoneHref} class="btn btn--action">Call Us Now</a>
      <a href="#quote-form" class="btn btn--outline">Get a Free Quote</a>
    </div>
    <p class="final-cta__reassurance">No obligation. No hidden fees. Just honest roofing.</p>
  </div>
</section>
