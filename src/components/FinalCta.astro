---
interface Props {
  phone?: string;
}

const { phone = '020 4634 7883' } = Astro.props;
const phoneHref = `tel:${phone.replace(/\s/g, '')}`;
---

<section class="final-cta">
  <div class="container">
    <h2>Ready to Fix Your Roof?</h2>
    <p class="final-cta__subtitle">Get a free, no-obligation quote from a team that's been trusted across Bristol for over 20 years.</p>
    <div class="final-cta__phone"><a href={phoneHref}>{phone}</a></div>
    <div class="final-cta__row">
      <a href={phoneHref} class="btn btn--call">Call Us Now</a>
      <a href="#quote-form" class="btn btn--outline">Get a Free Quote</a>
    </div>
    <p class="final-cta__reassurance">No obligation. No hidden fees. Just honest roofing.</p>
  </div>
</section>
