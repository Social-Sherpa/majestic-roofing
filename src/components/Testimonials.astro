---
import { Image } from 'astro:assets';
import avatar1 from '../assets/images/customer-avatar-1.webp';
import avatar2 from '../assets/images/customer-avatar-2.webp';
import avatar3 from '../assets/images/customer-avatar-3.webp';
import avatar4 from '../assets/images/customer-avatar-4.webp';
import googleLogo from '../assets/logos/google-colorful-logo.png';
import checkatradeLogo from '../assets/logos/checkatrade-approved-roofer.png';

interface Props {
  phone?: string;
}

const { phone = '020 4634 7883' } = Astro.props;
const phoneHref = `tel:${phone.replace(/\s/g, '')}`;

const testimonials = [
  {
    headline: 'Honest advice and a fair price',
    body: 'Had a nightmare with a persistent leak every time it rained heavy. Hammerslate came out, found the cracked tiles that two other builders had missed, and sorted it the same afternoon. No hard sell, just honest advice and a fair price. Really relieved to have it watertight again.',
    avatar: avatar1,
    name: 'Location: EN2',
    job: 'Roof Repair',
    platformLogo: googleLogo,
    platformAlt: 'Google Reviews',
    platformClass: 'google',
  },
  {
    headline: 'Completed on time and to a high standard',
    body: 'They did an excellent job on our roofing project, completing it on time and to a high standard. The team was polite, understanding, and respectful, especially towards my mother, which meant a lot to us. Their professionalism and attention to detail are truly commendable.',
    avatar: avatar2,
    name: 'Location: N14',
    job: 'New Roof',
    platformLogo: googleLogo,
    platformAlt: 'Google Reviews',
    platformClass: 'google',
  },
  {
    headline: 'Speed and expertise',
    body: 'All rubbish was quickly removed and the premises were left clean and tidy. The team was very punctual and polite and showed excellent workmanship. I have no hesitation in recommending Hammerslate Roofing for their speed and expertise.',
    avatar: avatar3,
    name: 'Location: N21',
    job: 'Roof Repair',
    platformLogo: checkatradeLogo,
    platformAlt: 'Checkatrade',
    platformClass: 'checkatrade',
  },
  {
    headline: 'Top-notch finish on our slate re-roof',
    body: "We decided to go for a full re-roof using slate, and the team at Hammerslate were brilliant from start to finish. They arrived early every morning, kept the driveway tidy, and the finish is top-notch. It's rare to find tradesmen who actually take pride in the neatness of the leadwork these days.",
    avatar: avatar4,
    name: 'Location: E17',
    job: 'Full Re-Roof (Slate)',
    platformLogo: googleLogo,
    platformAlt: 'Google Reviews',
    platformClass: 'google',
  },
];
---

<section class="section">
  <div class="container">
    <div class="section__header">
      <h2>What Our Customers Say</h2>
      <p>Real reviews from real homeowners across Enfield</p>
    </div>
    <div class="testimonials-grid">
      {testimonials.map((t, i) => (
        <div class="testimonial-card" data-slide={i}>
          <div class="testimonial-card__quote-mark">&ldquo;</div>
          <div class="testimonial-card__headline">{t.headline}</div>
          <p class="testimonial-card__body">{t.body}</p>
          <div class="testimonial-card__footer">
            <div class="testimonial-card__author">
              <Image src={t.avatar} alt={t.name} width={80} quality={80} class="testimonial-card__avatar" />
              <div>
                <div class="testimonial-card__name">{t.name}</div>
                <div class="testimonial-card__job">{t.job}</div>
              </div>
            </div>
            <div class="testimonial-card__rating">
              <div class="testimonial-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
              <Image src={t.platformLogo} alt={t.platformAlt} width={200} quality={100} class={`testimonial-card__platform-logo testimonial-card__platform-logo--${t.platformClass}`} />
            </div>
          </div>
        </div>
      ))}
    </div>
    <div class="testimonials-dots">
      {testimonials.map((_, i) => (
        <button class={`testimonials-dot ${i === 0 ? 'active' : ''}`} data-dot={i} aria-label={`Show review ${i + 1}`} />
      ))}
    </div>
    <div class="mid-cta">
      <a href="#quote-form" class="btn btn--action">Get Your Free Roofing Quote</a>
      <span class="mid-cta__phone">Or call us now: <a href={phoneHref}>{phone}</a></span>
    </div>
  </div>
</section>

<script>
  function initSlider() {
    const grid = document.querySelector('.testimonials-grid');
    const dots = document.querySelectorAll('.testimonials-dot');
    if (!grid || !dots.length || window.innerWidth > 640) return;

    let current = 0;
    const total = dots.length;
    let interval: ReturnType<typeof setInterval>;

    function goTo(index: number) {
      current = index;
      const card = grid.children[current] as HTMLElement;
      grid.scrollTo({ left: card.offsetLeft - 16, behavior: 'smooth' });
      dots.forEach((d, i) => d.classList.toggle('active', i === current));
    }

    function startAuto() {
      interval = setInterval(() => goTo((current + 1) % total), 4000);
    }

    function stopAuto() {
      clearInterval(interval);
    }

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => { stopAuto(); goTo(i); startAuto(); });
    });

    grid.addEventListener('touchstart', stopAuto, { passive: true });
    grid.addEventListener('touchend', () => {
      setTimeout(() => {
        const scrollLeft = grid.scrollLeft;
        const cardWidth = (grid.children[0] as HTMLElement).offsetWidth;
        current = Math.round(scrollLeft / cardWidth);
        dots.forEach((d, i) => d.classList.toggle('active', i === current));
        startAuto();
      }, 100);
    }, { passive: true });

    startAuto();
  }

  initSlider();
</script>
