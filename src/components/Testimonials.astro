---
import { Image } from 'astro:assets';
import avatar1 from '../assets/images/customer-avatar-1.webp';
import avatar2 from '../assets/images/customer-avatar-2.webp';
import avatar3 from '../assets/images/customer-avatar-3.webp';
import avatar4 from '../assets/images/customer-avatar-4.webp';
import googleLogo from '../assets/logos/google-colorful-logo.png';
import checkatradeLogo from '../assets/logos/checkatrade-approved-roofer.png';

interface Props {
  phone?: string;
}

const { phone = '01225 985713' } = Astro.props;
const phoneHref = `tel:${phone.replace(/\s/g, '')}`;

const testimonials = [
  {
    headline: 'Delivered everything he promised',
    body: "John delivered everything he promised. His team worked their nuts off stripping the roof, replacing all batons and a new breathable membrane, and then replacing all tiles. Brilliant job, would highly recommend.",
    avatar: avatar4,
    name: 'Rob Mason',
    job: 'Full Re-Roof',
    platformLogo: googleLogo,
    platformAlt: 'Google Reviews',
    platformClass: 'google',
  },
  {
    headline: 'Quick to quote, got a guarantee too',
    body: "Had a leak in the kitchen extension, John came next day to quote me, then we agreed a date for the repair works. Got a guarantee document too. Happy with the service.",
    avatar: avatar1,
    name: 'Lizzie McCall',
    job: 'Roof Repair',
    platformLogo: googleLogo,
    platformAlt: 'Google Reviews',
    platformClass: 'google',
  },
  {
    headline: 'Great job rebuilding our garage roof',
    body: "Max and the team did a great job with rebuilding our garage roof, quick and efficient service for a very reasonable price. Really happy. Definitely recommend.",
    avatar: avatar2,
    name: 'Jordan H',
    job: 'Garage Roof',
    platformLogo: googleLogo,
    platformAlt: 'Google Reviews',
    platformClass: 'google',
  },
  {
    headline: 'Roof and gutters look great',
    body: "Excellent experience with Majestic Services. They replaced our roof and our gutters. Their price was competitive, communication was good, the roof and new gutters look great. They also cleared up well.",
    avatar: avatar3,
    name: 'Christine Thomas',
    job: 'Roof & Gutters',
    platformLogo: googleLogo,
    platformAlt: 'Google Reviews',
    platformClass: 'google',
  },
];
---

<section class="section" id="reviews" style="padding: 28px 0;">
  <div class="container">
    <div class="section__header">
      <h2>What Our Customers Say</h2>
      <p>Real reviews from real homeowners across Bath</p>
    </div>
    <div class="testimonials-grid">
      {testimonials.map((t, i) => (
        <div class="testimonial-card" data-slide={i}>
          <div class="testimonial-card__quote-mark">&ldquo;</div>
          <div class="testimonial-card__headline">{t.headline}</div>
          <p class="testimonial-card__body">{t.body}</p>
          <div class="testimonial-card__footer">
            <div class="testimonial-card__author">
              <Image src={t.avatar} alt={t.name} width={40} height={40} quality={80} class="testimonial-card__avatar" />
              <div>
                <div class="testimonial-card__name">{t.name}</div>
                <div class="testimonial-card__job">{t.job}</div>
              </div>
            </div>
            <div class="testimonial-card__rating">
              <div class="testimonial-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
              <Image src={t.platformLogo} alt={t.platformAlt} width={80} height={22} quality={100} class={`testimonial-card__platform-logo testimonial-card__platform-logo--${t.platformClass}`} />
            </div>
          </div>
        </div>
      ))}
    </div>
    <div class="testimonials-dots">
      {testimonials.map((_, i) => (
        <button class={`testimonials-dot ${i === 0 ? 'active' : ''}`} data-dot={i} aria-label={`Show review ${i + 1}`} />
      ))}
    </div>
    <div class="mid-cta">
      <div class="mid-cta__content">
        <a href="#quote-form" class="btn btn--action">Get Your Free Roofing Quote</a>
        <div class="mid-cta__phone">Or call us now: <a href={phoneHref}>{phone}</a></div>
      </div>
    </div>
  </div>
</section>

<script>
  function initSlider() {
    if (!window.matchMedia('(max-width: 640px)').matches) return;

    const grid = document.querySelector('.testimonials-grid');
    const dots = document.querySelectorAll('.testimonials-dot');
    if (!grid || !dots.length) return;

    let current = 0;
    const total = dots.length;
    let interval: ReturnType<typeof setInterval>;

    function goTo(index: number) {
      current = index;
      const card = grid.children[current] as HTMLElement;
      grid.scrollTo({ left: card.offsetLeft - 16, behavior: 'smooth' });
      dots.forEach((d, i) => d.classList.toggle('active', i === current));
    }

    function startAuto() {
      interval = setInterval(() => goTo((current + 1) % total), 4000);
    }

    function stopAuto() {
      clearInterval(interval);
    }

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => { stopAuto(); goTo(i); startAuto(); });
    });

    grid.addEventListener('touchstart', stopAuto, { passive: true });
    grid.addEventListener('touchend', () => {
      setTimeout(() => {
        const scrollLeft = grid.scrollLeft;
        const cardWidth = (grid.children[0] as HTMLElement).offsetWidth;
        current = Math.round(scrollLeft / cardWidth);
        dots.forEach((d, i) => d.classList.toggle('active', i === current));
        startAuto();
      }, 100);
    }, { passive: true });

    startAuto();
  }

  initSlider();
</script>
