---
import { Image } from 'astro:assets';
import newRoofImg from '../../assets/roofing/images/bath/new-roof-grey-tile-bath.webp';
import roofRepairImg from '../../assets/roofing/images/bath/roof-repair-ridge-tiles-bath.webp';
import flatRoofImg from '../../assets/roofing/images/bath/flat-roof-grp-bath.webp';
import gutteringImg from '../../assets/roofing/images/bath/guttering-fascias-bath.webp';
import chimneyImg from '../../assets/roofing/images/bath/chimney-leadwork-bath.webp';
import emergencyImg from '../../assets/roofing/images/bath/emergency-roof-repair-bath.webp';
import vanImg from '../../assets/roofing/images/brand-images/tmppch84kot.webp';

interface Props {
  phone?: string;
  location?: string;
}

const { phone = '01225 985713', location = 'Enfield' } = Astro.props;
const phoneHref = `tel:${phone.replace(/\s/g, '')}`;

const services = [
  { label: 'New Roof / Re-Roof', img: newRoofImg, alt: `New grey tile roof fitted by Majestic Roofing in ${location}` },
  { label: 'Roof Repairs', img: roofRepairImg, alt: `Ridge tile repair on a ${location} property` },
  { label: 'Flat Roofs', img: flatRoofImg, alt: `New GRP flat roof installation on a ${location} home` },
  { label: 'Guttering & Fascias', img: gutteringImg, alt: `New black guttering and fascias fitted on a ${location} house` },
  { label: 'Chimney Repairs', img: chimneyImg, alt: `Chimney leadwork and flashing repair in ${location}` },
  { label: 'Emergency Roof Repair', img: emergencyImg, alt: `Emergency slate roof repair by Majestic Roofing in ${location}` },
];
---

<section class="section">
  <div class="container">
    <div class="section__header">
      <h2>Professional Roofing Services in {location}</h2>
      <p>We handle everything from emergency leak repairs to complete new roofs. Every job includes a free survey and a fixed written quote.</p>
    </div>
    <div class="services-grid">
      {services.map((s) => (
        <div class="service-card">
          <Image src={s.img} alt={s.alt} widths={[300, 450]} loading="lazy" />
          <div class="service-card__overlay"></div>
          <div class="service-card__label">{s.label}</div>
        </div>
      ))}
    </div>
    <div class="mid-cta">
      <div class="mid-cta__content">
        <a href="#quote-form" class="btn btn--action">Get Your Free Roofing Quote</a>
        <div class="mid-cta__phone">Call For An Instant Quote</div>
        <div class="mid-cta__number"><a href={phoneHref}>{phone}</a></div>
      </div>
      <div class="mid-cta__van">
        <Image src={vanImg} alt="Majestic Roofing van" widths={[300, 500]} loading="lazy" />
      </div>
    </div>
  </div>
</section>
