---
import { Image } from 'astro:assets';
import logo from '../../assets/roofing/logos/majestic-logo.png';
import checkatradeLogo from '../../assets/roofing/logos/checkatrade-approved-roofer.png';
import phoneIcon from '../../assets/roofing/icons/phone.png';

interface Props {
  phone?: string;
}

const { phone = '01225 985713' } = Astro.props;
const phoneHref = `tel:${phone.replace(/\s/g, '')}`;
---

<header class="header">
  <div class="header__inner">
    <a class="header__logo" href="#">
      <Image src={logo} alt="Majestic Roofing logo" width={376} quality={100} format="png" loading="eager" />
    </a>

    <div class="header__right">
      <div class="header__badges">
        <div class="header__badge header__badge--checkatrade">
          <Image src={checkatradeLogo} alt="Checkatrade approved roofer" width={400} quality={100} format="png" loading="eager" />
          <div class="header__badge-text">
            <span class="header__badge-score"><strong>Rated 10/10</strong> (40+ Reviews)</span>
          </div>
        </div>
      </div>

      <div class="header__phone">
        <div>
          <div class="header__phone-number">
            <a href={phoneHref}>
              <Image src={phoneIcon} alt="" class="header__phone-icon" width={96} height={96} loading="eager" />
              <span>{phone}</span>
            </a>
          </div>
          <div class="header__phone-label">Call Us For a Free Quote</div>
        </div>
      </div>
    </div>
  </div>
</header>
