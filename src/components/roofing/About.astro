---
import { Image } from 'astro:assets';
import img1 from '../../assets/roofing/images/brand-images/brand-house.jpeg';
import img2 from '../../assets/roofing/images/client/black-slate-roof-tiles-brick-house.jpg';
import img3 from '../../assets/roofing/images/client/slate-roof-installation-with-chimney.jpg';
import img4 from '../../assets/roofing/images/client/red-brick-chimney-on-roof.jpg';
import img5 from '../../assets/roofing/images/client/flat-roof-rubber-membrane-installation.jpg';
import img6 from '../../assets/roofing/images/client/black-guttering-downpipe-system.jpg';
import img7 from '../../assets/roofing/images/client/new-roof-installation-construction-project.jpg';
import img8 from '../../assets/roofing/images/client/brick-house-modern-dark-roof.jpg';

interface Props {
  phone?: string;
  location?: string;
}

const { phone = '01225 985713', location = 'Bath' } = Astro.props;

const gallery = [
  { src: img1, alt: 'Completed roofing project on a residential property in Bath' },
  { src: img2, alt: 'Black slate roof tiles fitted on a brick house' },
  { src: img3, alt: 'Slate roof installation with chimney work' },
  { src: img4, alt: 'Red brick chimney repair on a residential roof' },
  { src: img5, alt: 'Flat roof rubber membrane installation' },
  { src: img6, alt: 'Black guttering and downpipe system on a brick house' },
  { src: img7, alt: 'New roof installation construction project in progress' },
  { src: img8, alt: 'Modern dark roof on a brick house' },
];
---

<section class="section section--off-white">
  <div class="container">
    <div class="about-split">
      <div class="about-split__image about-split__slider">
        <div class="about-slider__track">
          {gallery.map((img) => (
            <div class="about-slider__slide">
              <Image
                src={img.src}
                alt={img.alt}
                widths={[400, 600]}
                loading="lazy"
                class="about-slider__img"
              />
            </div>
          ))}
        </div>
        <button class="about-slider__arrow about-slider__arrow--prev" aria-label="Previous slide">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        <button class="about-slider__arrow about-slider__arrow--next" aria-label="Next slide">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
        <div class="about-slider__dots"></div>
      </div>
      <div class="about-split__content">
        <h2>Serving {location} for Over 20 Years</h2>
        <p>Majestic Services is a family-run roofing business led by John, who personally oversees every project from first inspection to final clean-up. We built our reputation on doing honest work at fair prices, and our customers keep coming back.</p>
        <p>We don't believe in hidden charges or call-out fees. You'll get a detailed written quote before any work starts, and every job is backed by our 15-year workmanship warranty.</p>
        <ul class="about-split__checks">
          <li>Fully insured and qualified team</li>
          <li>Free pre-work survey and inspection</li>
          <li>15-year workmanship warranty</li>
          <li>No call-out fees, no hidden costs</li>
          <li>24/7 emergency availability</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<script>
  const slider = document.querySelector('.about-split__slider');
  if (slider) {
    const slides = slider.querySelectorAll('.about-slider__slide');
    const dotsContainer = slider.querySelector('.about-slider__dots');
    const prevBtn = slider.querySelector('.about-slider__arrow--prev');
    const nextBtn = slider.querySelector('.about-slider__arrow--next');
    const total = slides.length;
    let current = 0;
    let interval: ReturnType<typeof setInterval>;

    slides[0]?.classList.add('active');

    slides.forEach((_, i) => {
      const dot = document.createElement('button');
      dot.className = `about-slider__dot${i === 0 ? ' active' : ''}`;
      dot.setAttribute('aria-label', `Show image ${i + 1}`);
      dot.addEventListener('click', () => { stopAuto(); goTo(i); startAuto(); });
      dotsContainer?.appendChild(dot);
    });

    const dots = dotsContainer?.querySelectorAll('.about-slider__dot');

    function goTo(index: number) {
      current = ((index % total) + total) % total;
      slides.forEach((s, i) => s.classList.toggle('active', i === current));
      dots?.forEach((d, i) => d.classList.toggle('active', i === current));
    }

    function startAuto() {
      interval = setInterval(() => goTo(current + 1), 4000);
    }

    function stopAuto() {
      clearInterval(interval);
    }

    prevBtn?.addEventListener('click', () => { stopAuto(); goTo(current - 1); startAuto(); });
    nextBtn?.addEventListener('click', () => { stopAuto(); goTo(current + 1); startAuto(); });

    startAuto();
  }
</script>
