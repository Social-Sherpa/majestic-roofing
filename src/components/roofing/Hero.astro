---
import { Image } from 'astro:assets';
import heroImg from '../../assets/roofing/images/bath/hero-slate-reroof-bath.webp';
import heroMobileImg from '../../assets/roofing/images/bath/hero-mobile-clay-tile-bath.webp';
import googleGLogo from '../../assets/roofing/logos/google-g-logo-colorful.jpg';
import avatar1 from '../../assets/roofing/images/thispersondoesnotexist.jpg';
import QuoteForm from './QuoteForm.astro';

interface Testimonial {
  body: string;
  name: string;
  date: string;
  service: string;
}

interface Props {
  headline: string;
  subtitle: string;
  webhookUrl: string;
  phone?: string;
  source?: string;
  testimonial?: Testimonial;
}

const {
  headline,
  subtitle,
  webhookUrl,
  phone = '01225 985713',
  source = 'Landing Page',
  testimonial = {
    body: "John delivered everything he promised. His team worked their nuts off stripping the roof, replacing all batons and a new breathable membrane, and then replacing all tiles. Brilliant job, would highly recommend.",
    name: 'Rob Mason, Bath',
    date: 'Apr 2025',
    service: 'Full Re-Roof',
  },
} = Astro.props;

const phoneHref = `tel:${phone.replace(/\s/g, '')}`;
---

<section class="hero">
  <Image
    src={heroImg}
    alt="Full slate re-roof in progress on a Bath property by Majestic Roofing"
    class="hero__bg"
    widths={[600, 900, 1200]}
    loading="eager"
  />
  <div class="hero__mobile-image">
    <Image
      src={heroMobileImg}
      alt="Close-up of a completed clay tile roof by Majestic Roofing in Bath"
      class="hero__mobile-img"
      widths={[600, 900]}
      loading="eager"
    />
  </div>
  <div class="hero__grid">
    <div class="hero__content">
      <div class="hero__rating">
        <span class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        <span>Rated "Excellent" (97 Reviews)</span>
      </div>
      <h1 class="hero__title">{headline}</h1>
      <p class="hero__subtitle">{subtitle}</p>
    </div>

    <div class="hero__form-col">
      <QuoteForm webhookUrl={webhookUrl} source={source} phone={phone} />
    </div>

    <div class="hero-testimonial">
      <p class="hero-testimonial__body">{testimonial.body}</p>
      <hr class="hero-testimonial__divider" />
      <div class="hero-testimonial__footer">
        <div class="hero-testimonial__info">
          <div class="hero-testimonial__meta">
            <div class="hero-testimonial__top-row">
              <span class="hero-testimonial__name">{testimonial.name}</span>
              <span class="hero-testimonial__date">({testimonial.date})</span>
            </div>
            <span class="hero-testimonial__service">{testimonial.service}</span>
          </div>
          <div class="hero-testimonial__avatar-wrap">
            <Image
              src={avatar1}
              alt="Customer photo"
              class="hero-testimonial__avatar"
              widths={[48, 96]}
            />
            <Image
              src={googleGLogo}
              alt="Google"
              class="hero-testimonial__g-badge"
              widths={[18, 36]}
            />
          </div>
        </div>
        <div class="hero-testimonial__badges">
          <span class="hero-testimonial__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
          <span class="hero-testimonial__verified">Verified</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Grid layout: content + card on left column, form on right */
  .hero__grid {
    display: grid;
    grid-template-columns: 1fr 400px;
    grid-template-rows: auto auto;
    gap: 56px 56px;
    align-items: start;
    padding: 72px 24px 80px;
    max-width: var(--max-width);
    margin: 0 auto;
    position: relative;
    box-sizing: border-box;
  }

  .hero__grid > .hero__content {
    grid-column: 1;
    grid-row: 1;
  }

  .hero__form-col {
    grid-column: 2;
    grid-row: 1 / 3;
  }

  .hero-testimonial {
    grid-column: 1;
    grid-row: 2;
    background: rgba(255, 255, 255, 0.97);
    border-radius: var(--radius-lg);
    padding: 24px 28px 20px;
    max-width: 520px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
    margin-top: -24px;
  }

  .hero-testimonial__body {
    color: var(--text);
    font-size: 0.95rem;
    line-height: 1.65;
    margin: 0;
  }

  .hero-testimonial__divider {
    border: none;
    border-top: 1px solid #e5e5e3;
    margin: 18px 0 16px;
  }

  .hero-testimonial__footer {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .hero-testimonial__info {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .hero-testimonial__meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hero-testimonial__top-row {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }

  .hero-testimonial__name {
    font-weight: 700;
    color: var(--text);
    font-size: 0.9rem;
  }

  .hero-testimonial__date {
    color: var(--text-secondary);
    font-size: 0.85rem;
  }

  .hero-testimonial__service {
    color: var(--text-secondary);
    font-size: 0.85rem;
  }

  .hero-testimonial__badges {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .hero-testimonial__stars {
    color: var(--gold);
    font-size: 1.05rem;
    letter-spacing: 1px;
  }

  .hero-testimonial__verified {
    background: #e8f5e9;
    color: #2e7d32;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 4px;
  }

  .hero-testimonial__avatar-wrap {
    position: relative;
    width: 64px;
    height: 64px;
    flex-shrink: 0;
  }

  .hero-testimonial__avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    object-fit: cover;
    display: block;
  }

  .hero-testimonial__g-badge {
    position: absolute;
    bottom: -2px;
    right: -2px;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid white;
    display: block;
  }

  /* Tablet */
  @media (max-width: 960px) {
    .hero__grid {
      grid-template-columns: 1fr;
      gap: 36px;
      padding: 48px 16px 56px;
    }

    .hero__grid > .hero__content {
      text-align: center;
    }

    .hero__form-col {
      grid-column: 1;
      grid-row: 2;
      max-width: 440px;
      margin: 0 auto;
      width: 100%;
    }


    .hero-testimonial {
      grid-column: 1;
      grid-row: 3;
      margin: 0 auto;
      max-width: 440px;
      width: 100%;
    }
  }

  /* Mobile */
  @media (max-width: 640px) {
    .hero__grid {
      padding: 20px 16px 32px;
      gap: 16px;
      overflow-x: hidden;
    }

    .hero-testimonial {
      margin-top: 0;
      box-sizing: border-box;
      max-width: 100%;
      padding-bottom: 10px;
    }

    .hero-testimonial__footer {
      gap: 0;
    }

    .hero__form-col {
      max-width: 100%;
      box-sizing: border-box;
    }
  }
</style>
