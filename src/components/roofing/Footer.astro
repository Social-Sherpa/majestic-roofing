---
interface Props {
  phone?: string;
}

const { phone = '01225 985713' } = Astro.props;
const phoneHref = `tel:${phone.replace(/\s/g, '')}`;
---

<footer class="footer">
  <div class="container">
    <div class="footer__map">
      <iframe
        src="https://maps.google.com/maps?q=Bath,+UK&output=embed"
        width="100%"
        height="250"
        style="border:0; border-radius: var(--radius-lg);"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Majestic Roofing location on Google Maps"
      ></iframe>
    </div>
    <div class="footer__inner">
      <div>
        <div class="footer__brand">Majestic Roofing</div>
        <p>Family-run roofing experts serving Bath. Fully insured, fully guaranteed, and always here to help.</p>
        <p style="margin-top:12px;"><a href={phoneHref} style="color:var(--white);">{phone}</a></p>
        <p>Bath, Somerset</p>
      </div>
      <div>
        <h4>Services</h4>
        <ul>
          <li>New Roofs / Re-Roofs</li>
          <li>Roof Repairs</li>
          <li>Flat Roofs</li>
          <li>Guttering &amp; Fascias</li>
          <li>Chimney Repairs</li>
          <li>Emergency Repairs</li>
        </ul>
      </div>
      <div>
        <h4>Areas We Cover</h4>
        <ul>
          <li>Bath</li>
          <li>Bristol</li>
          <li>Trowbridge</li>
          <li>Frome, Keynsham, Bradford on Avon</li>
        </ul>
      </div>
    </div>
    <div class="footer__bottom">
      <span>&copy; {new Date().getFullYear()} Majestic Roofing. All rights reserved.</span>
      <span><a href="#">Privacy Policy</a></span>
    </div>
  </div>
</footer>
