---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/png" href="/favicon.png">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <slot />
</body>
</html>

<style is:global>
  /* ============================================
     LANDSCAPING V2 DESIGN TOKENS
     ============================================ */
  :root {
    --ls2-brand: #2d3480;
    --ls2-brand-light: #3a4199;
    --ls2-action: #3a7d44;
    --ls2-action-hover: #2f6938;
    --ls2-white: #ffffff;
    --ls2-off-white: #f8f8f8;
    --ls2-text: #161616;
    --ls2-text-secondary: #4a4a4a;
    --ls2-text-light: #6b6b6b;
    --ls2-gold: #f4b942;
    --ls2-border: #e5e4e2;
    --ls2-light-grey: #f2f1ef;
    --ls2-radius: 6px;
    --ls2-radius-lg: 10px;
    --ls2-max-width: 1140px;
    --ls2-shadow-sm: 0 1px 3px rgba(0,0,0,0.06);
    --ls2-shadow-md: 0 4px 16px rgba(0,0,0,0.08);
    --ls2-shadow-lg: 0 20px 60px rgba(0,0,0,0.12);
  }

  /* ============================================
     RESET & BASE
     ============================================ */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-weight: 400;
    font-size: 17px;
    line-height: 1.6;
    color: var(--ls2-text);
    background: var(--ls2-white);
  }

  img { max-width: 100%; height: auto; display: block; }
  a { color: inherit; text-decoration: none; }

  .ls2-container {
    max-width: var(--ls2-max-width);
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ============================================
     TYPOGRAPHY
     ============================================ */
  h1, h2, h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 700;
    line-height: 1.15;
    color: var(--ls2-text);
  }

  h1 { font-size: clamp(2.2rem, 5vw, 3.2rem); }
  h2 { font-size: clamp(1.75rem, 3.5vw, 2.4rem); }
  h3 { font-size: clamp(1.1rem, 2vw, 1.35rem); }

  /* ============================================
     SECTION HELPERS
     ============================================ */
  .ls2-section {
    padding: 64px 0;
  }

  .ls2-section--off-white {
    background: var(--ls2-off-white);
  }

  .ls2-section__header {
    text-align: center;
    margin-bottom: 48px;
  }

  .ls2-section__header p {
    color: var(--ls2-text-secondary);
    font-size: 1.05rem;
    margin-top: 12px;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ============================================
     BUTTONS
     ============================================ */
  .ls2-btn {
    display: inline-block;
    padding: 14px 32px;
    border-radius: var(--ls2-radius);
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 1rem;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s ease;
    border: 2px solid transparent;
  }

  .ls2-btn--action {
    background: var(--ls2-action);
    color: var(--ls2-white);
  }

  .ls2-btn--action:hover {
    background: var(--ls2-action-hover);
  }

  .ls2-btn--call {
    background: var(--ls2-action);
    color: var(--ls2-white);
  }

  .ls2-btn--call:hover {
    background: var(--ls2-action-hover);
  }

  .ls2-btn--outline {
    background: transparent;
    color: var(--ls2-white);
    border: 2px solid var(--ls2-white);
  }

  .ls2-btn--outline:hover {
    background: rgba(255,255,255,0.1);
  }

  /* ============================================
     MID CTA
     ============================================ */
  .ls2-mid-cta {
    text-align: center;
    margin-top: 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .ls2-mid-cta__phone {
    font-size: 0.95rem;
    color: var(--ls2-text-secondary);
  }

  .ls2-mid-cta__phone a {
    color: var(--ls2-action);
    font-weight: 600;
  }
</style>
