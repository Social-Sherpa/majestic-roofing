<style>
  /* ============================================
     HEADER
     ============================================ */
  .ls2-header {
    background: var(--ls2-white);
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid #e8e8e6;
  }

  .ls2-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 6px 24px;
    max-width: var(--ls2-max-width);
    margin: 0 auto;
  }

  .ls2-header__right {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .ls2-header__logo {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .ls2-header__logo img {
    height: 86px;
    width: auto;
  }

  .ls2-header__badges {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .ls2-header__badge {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .ls2-header__badge--reviews img {
    width: 110px;
    height: auto;
  }

  .ls2-header__badge--checkatrade img {
    width: 80px;
    height: auto;
  }

  .ls2-header__badge-text {
    display: flex;
    flex-direction: column;
    font-size: 0.72rem;
    color: var(--ls2-text-secondary);
    line-height: 1.3;
  }

  .ls2-header__badge-score {
    font-size: 0.75rem;
  }

  .ls2-header__badge-detail {
    color: var(--ls2-text-light);
    font-size: 0.7rem;
  }

  .ls2-header__badge-divider {
    width: 1px;
    height: 36px;
    background: var(--ls2-border);
  }

  .ls2-header__phone {
    display: flex;
    align-items: center;
    gap: 10px;
    text-align: right;
  }

  .ls2-header__phone-number {
    font-size: 1.15rem;
    font-weight: 700;
    font-family: 'Inter', sans-serif;
  }

  .ls2-header__phone-number a {
    color: var(--ls2-brand);
  }

  .ls2-header__phone-label {
    font-size: 0.7rem;
    color: var(--ls2-text-light);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  @media (max-width: 960px) {
    .ls2-header__badges {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .ls2-header__inner {
      padding: 8px 16px;
    }

    .ls2-header__logo img {
      height: 54px;
    }

    .ls2-header__phone-label {
      display: none;
    }

    .ls2-header__phone-number {
      font-size: 0.95rem;
    }
  }

  /* ============================================
     TRUST STRIP
     ============================================ */
  .ls2-trust-strip {
    background: var(--ls2-brand);
    padding: 10px 0;
  }

  .ls2-trust-strip__inner {
    display: flex;
    justify-content: center;
    gap: 40px;
    flex-wrap: wrap;
  }

  .ls2-trust-strip__item {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--ls2-white);
    font-size: 0.85rem;
    font-weight: 500;
    white-space: nowrap;
  }

  .ls2-trust-strip__icon {
    display: flex;
    align-items: center;
  }

  .ls2-trust-strip__icon svg {
    width: 18px;
    height: 18px;
    fill: var(--ls2-gold);
  }

  @media (max-width: 640px) {
    .ls2-trust-strip__inner {
      gap: 12px 24px;
    }

    .ls2-trust-strip__item {
      font-size: 0.75rem;
    }
  }

  /* ============================================
     HERO
     ============================================ */
  .ls2-hero {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ls2-hero--compact {
    min-height: 420px;
  }

  .ls2-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .ls2-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.55);
    z-index: 1;
  }

  .ls2-hero__inner {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 80px 24px;
  }

  .ls2-hero__inner--compact {
    padding: 60px 24px 48px;
    max-width: 720px;
  }

  .ls2-hero__content {
    color: var(--ls2-white);
  }

  .ls2-hero__rating {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-size: 0.95rem;
    margin-bottom: 16px;
    color: var(--ls2-white);
  }

  .ls2-stars {
    color: var(--ls2-gold);
    font-size: 1.15rem;
    letter-spacing: 2px;
  }

  .ls2-hero__title {
    color: var(--ls2-white);
    margin-bottom: 16px;
    text-shadow: 0 2px 12px rgba(0,0,0,0.3);
  }

  .ls2-hero__subtitle {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.9);
    max-width: 580px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .ls2-hero__scroll-arrow {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    opacity: 0.8;
    transition: opacity 0.2s;
  }

  .ls2-hero__scroll-arrow:hover {
    opacity: 1;
  }

  .ls2-hero__scroll-arrow img {
    width: 64px;
    height: 64px;
    filter: brightness(0) invert(1);
  }

  @media (max-width: 640px) {
    .ls2-hero--compact {
      min-height: 340px;
    }

    .ls2-hero__inner--compact {
      padding: 40px 16px 36px;
    }
  }

  /* ============================================
     FORM SECTION
     ============================================ */
  .ls2-form-section {
    background: var(--ls2-white);
    padding: 0;
  }

  .ls2-form-section__inner {
    max-width: 640px;
    text-align: center;
    padding-top: 48px;
  }

  .ls2-form-section__header {
    margin-bottom: 32px;
  }

  .ls2-form-section__title {
    margin-bottom: 8px;
  }

  .ls2-form-section__subtitle {
    color: var(--ls2-text-secondary);
    font-size: 1.05rem;
  }

  .ls2-form-tiles {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 20px;
  }

  .ls2-form-tile {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 18px 20px;
    border: 2px solid var(--ls2-border);
    border-radius: var(--ls2-radius-lg);
    cursor: pointer;
    transition: all 0.2s ease;
    background: var(--ls2-white);
  }

  .ls2-form-tile:hover {
    border-color: var(--ls2-action);
    background: rgba(58, 125, 68, 0.03);
  }

  .ls2-form-tile input {
    display: none;
  }

  .ls2-form-tile__radio {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 2px solid var(--ls2-border);
    flex-shrink: 0;
    position: relative;
    transition: all 0.2s ease;
  }

  .ls2-form-tile input:checked ~ .ls2-form-tile__radio {
    border-color: var(--ls2-action);
  }

  .ls2-form-tile input:checked ~ .ls2-form-tile__radio::after {
    content: '';
    position: absolute;
    top: 4px;
    left: 4px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--ls2-action);
  }

  .ls2-form-tile input:checked ~ .ls2-form-tile__label {
    font-weight: 600;
    color: var(--ls2-text);
  }

  .ls2-form-tile__label {
    font-size: 0.95rem;
    color: var(--ls2-text-secondary);
    font-weight: 500;
    text-align: left;
  }

  .ls2-form-progress {
    margin-bottom: 24px;
  }

  .ls2-form-progress__bar {
    height: 4px;
    background: var(--ls2-border);
    border-radius: 2px;
    overflow: hidden;
  }

  .ls2-form-progress__fill {
    height: 100%;
    width: 0%;
    background: var(--ls2-action);
    border-radius: 2px;
    transition: width 0.4s ease;
  }

  .ls2-form-step--hidden {
    display: none;
  }

  .ls2-form-fields {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 20px;
  }

  .ls2-form-field input {
    width: 100%;
    padding: 14px 16px;
    border: 2px solid var(--ls2-border);
    border-radius: var(--ls2-radius);
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    color: var(--ls2-text);
    transition: border-color 0.2s;
    outline: none;
  }

  .ls2-form-field input:focus {
    border-color: var(--ls2-action);
  }

  .ls2-form-field input::placeholder {
    color: var(--ls2-text-light);
  }

  .ls2-form-submit {
    width: 100%;
    padding: 16px;
    font-size: 1.05rem;
  }

  .ls2-form-section__or {
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--ls2-text-secondary);
    padding-bottom: 24px;
    margin-top: 16px;
  }

  .ls2-form-section__or a {
    color: var(--ls2-action);
  }

  @media (max-width: 480px) {
    .ls2-form-tiles {
      grid-template-columns: 1fr;
    }
  }

  /* ============================================
     ACCREDITATIONS
     ============================================ */
  .ls2-accreditations {
    background: var(--ls2-light-grey);
    padding: 32px 0;
  }

  .ls2-accreditations__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
  }

  .ls2-accreditations__item {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 24px;
    border-right: 1px solid var(--ls2-border);
  }

  .ls2-accreditations__item:last-child {
    border-right: none;
  }

  .ls2-accreditations__item img {
    height: 52px;
    width: auto;
    object-fit: contain;
    filter: grayscale(100%);
    opacity: 0.6;
    transition: all 0.3s ease;
  }

  .ls2-accreditations__item:hover img {
    filter: grayscale(0%);
    opacity: 1;
    transform: scale(1.05);
  }

  @media (max-width: 768px) {
    .ls2-accreditations__inner {
      flex-wrap: wrap;
      gap: 16px;
    }

    .ls2-accreditations__item {
      flex: 0 0 calc(33.33% - 16px);
      border-right: none;
      padding: 8px 16px;
    }
  }

  @media (max-width: 480px) {
    .ls2-accreditations__item {
      flex: 0 0 calc(50% - 16px);
    }
  }

  /* ============================================
     SERVICES GRID
     ============================================ */
  .ls2-services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .ls2-service-card {
    position: relative;
    border-radius: var(--ls2-radius-lg);
    overflow: hidden;
    aspect-ratio: 4/3;
    cursor: pointer;
  }

  .ls2-service-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .ls2-service-card:hover img {
    transform: scale(1.08);
  }

