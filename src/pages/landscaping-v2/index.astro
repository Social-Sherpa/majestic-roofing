</style>

<script>
  // ============================================
  // TWO-STEP FORM
  // ============================================
  const tiles = document.querySelectorAll('.ls2-form-tile input');
  const step1 = document.getElementById('ls2-form-step-1');
  const step2 = document.getElementById('ls2-form-step-2');
  const progressFill = document.getElementById('ls2-progress-fill');
  const hiddenService = document.getElementById('ls2-hidden-service') as HTMLInputElement;

  tiles.forEach((tile) => {
    tile.addEventListener('change', (e) => {
      const target = e.target as HTMLInputElement;
      if (hiddenService) hiddenService.value = target.value;
      if (progressFill) progressFill.style.width = '50%';

      setTimeout(() => {
        if (step2) step2.classList.remove('ls2-form-step--hidden');
        if (progressFill) progressFill.style.width = '100%';
        step2?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }, 400);
    });
  });

  // ============================================
  // FAQ ACCORDION
  // ============================================
  document.querySelectorAll('.ls2-faq-item__question').forEach((btn) => {
    btn.addEventListener('click', () => {
      btn.parentElement!.classList.toggle('active');
    });
  });

  // ============================================
  // ABOUT GALLERY
  // ============================================
  const gallery = document.querySelector('.ls2-about-gallery');
  if (gallery) {
    const slides = gallery.querySelectorAll('.ls2-about-gallery__slide');
    const dots = gallery.querySelectorAll('.ls2-about-gallery__dot');
    const prevBtn = gallery.querySelector('.ls2-about-gallery__arrow--prev');
    const nextBtn = gallery.querySelector('.ls2-about-gallery__arrow--next');
    const total = slides.length;
    let current = 0;
    let interval: ReturnType<typeof setInterval>;

    function goTo(index: number) {
      current = ((index % total) + total) % total;
      slides.forEach((s, i) => s.classList.toggle('active', i === current));
      dots.forEach((d, i) => d.classList.toggle('active', i === current));
    }

    function startAuto() {
      interval = setInterval(() => goTo(current + 1), 4000);
    }

    function stopAuto() {
      clearInterval(interval);
    }

    prevBtn?.addEventListener('click', () => { stopAuto(); goTo(current - 1); startAuto(); });
    nextBtn?.addEventListener('click', () => { stopAuto(); goTo(current + 1); startAuto(); });
    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => { stopAuto(); goTo(i); startAuto(); });
    });

    startAuto();
  }

  // ============================================
  // TESTIMONIALS MOBILE CAROUSEL
  // ============================================
  function initLs2Slider() {
    const grid = document.querySelector('.ls2-testimonials-grid');
    const dots = document.querySelectorAll('.ls2-testimonials-dot');
    if (!grid || !dots.length || window.innerWidth > 640) return;

    let current = 0;
    const total = dots.length;
    let interval: ReturnType<typeof setInterval>;

    function goTo(index: number) {
      current = index;
      const card = grid.children[current] as HTMLElement;
      grid.scrollTo({ left: card.offsetLeft - 16, behavior: 'smooth' });
      dots.forEach((d, i) => d.classList.toggle('active', i === current));
    }

    function startAuto() {
      interval = setInterval(() => goTo((current + 1) % total), 4000);
    }

    function stopAuto() {
      clearInterval(interval);
    }

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => { stopAuto(); goTo(i); startAuto(); });
    });

    grid.addEventListener('touchstart', stopAuto, { passive: true });
    grid.addEventListener('touchend', () => {
      setTimeout(() => {
        const scrollLeft = grid.scrollLeft;
        const cardWidth = (grid.children[0] as HTMLElement).offsetWidth;
        current = Math.round(scrollLeft / cardWidth);
        dots.forEach((d, i) => d.classList.toggle('active', i === current));
        startAuto();
      }, 100);
    }, { passive: true });

    startAuto();
  }

  initLs2Slider();

  // ============================================
  // PLATFORM RATINGS COUNTER ANIMATION
  // ============================================
  function animateLs2Counters() {
    const counters = document.querySelectorAll('.ls2-counter');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.target || '0');
        const duration = 1500;
        const start = performance.now();

        function update(now: number) {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = Math.floor(eased * target).toString();
          if (progress < 1) requestAnimationFrame(update);
        }

        requestAnimationFrame(update);
        observer.unobserve(el);
      });
    }, { threshold: 0.5 });

    counters.forEach((c) => observer.observe(c));
  }

  animateLs2Counters();
</script>
