---
import { Image } from 'astro:assets';
import LandscapingV2Layout from '../../layouts/LandscapingV2Layout.astro';

// Images
import heroImg from '../../assets/images/landscaping/hero-landscaped-garden-bath.png';
import teamImg from '../../assets/images/landscaping/team-laying-paving-bath.png';
import galleryPatio from '../../assets/images/landscaping/gallery-stone-patio-bath.png';
import galleryDriveway from '../../assets/images/landscaping/gallery-block-paving-driveway.png';
import galleryGrass from '../../assets/images/landscaping/gallery-new-lawn-borders.png';
import galleryFencing from '../../assets/images/landscaping/gallery-timber-fencing.png';
import galleryDecking from '../../assets/images/landscaping/gallery-composite-decking.png';
import galleryGarden from '../../assets/images/landscaping/gallery-garden-transformation.png';

// Brand
import logo from '../../assets/brand/Majestic property services 500x200.png';

// Logos
import reviewIcons from '../../assets/logos/review-platform-icons.webp';
import checkatradeLogo from '../../assets/logos/checkatrade-approved-roofer.png';
import googleLogo from '../../assets/logos/google-colorful-logo.png';
import facebookLogo from '../../assets/logos/Facebook.png';

// Accreditation logos
import nhbc from '../../assets/logos/NHBC.webp';
import constructionline from '../../assets/logos/Constructiononline.webp';
import masterBuilders from '../../assets/logos/MasterBuilders.webp';
import chas from '../../assets/logos/CHAS.webp';
import nfrc from '../../assets/logos/NFRC.webp';
import corc from '../../assets/logos/Confederation-of-roofing-contractors.webp';

// Customer avatars
import avatar1 from '../../assets/images/customer-avatar-1.webp';
import avatar2 from '../../assets/images/customer-avatar-2.webp';
import avatar3 from '../../assets/images/customer-avatar-3.webp';
import avatar4 from '../../assets/images/customer-avatar-4.webp';

const phone = '01225 985713';
const phoneHref = `tel:${phone.replace(/\s/g, '')}`;

const services = [
  { label: 'Garden Design & Landscaping', img: galleryDecking, alt: 'Composite decking and garden design in Bath' },
  { label: 'Patios & Paving', img: galleryPatio, alt: 'Indian sandstone patio laid in a Bath garden' },
  { label: 'Driveways & Block Paving', img: galleryDriveway, alt: 'Block paving driveway installed in Bath' },
  { label: 'Fencing & Decking', img: galleryFencing, alt: 'Timber fencing and garden boundary in Bath' },
  { label: 'Artificial Grass & Lawns', img: galleryGrass, alt: 'New lawn and garden borders in Bath' },
  { label: 'Garden Clearance', img: galleryGarden, alt: 'Complete garden transformation and clearance in Bath' },
];

const accreditationLogos = [
  { src: nhbc, alt: 'NHBC accredited' },
  { src: constructionline, alt: 'Constructionline certified' },
  { src: masterBuilders, alt: 'Federation of Master Builders member' },
  { src: chas, alt: 'CHAS accredited contractor' },
  { src: nfrc, alt: 'NFRC certified' },
  { src: corc, alt: 'Confederation of Contractors member' },
];

const testimonials = [
  {
    headline: 'Transformed our tired garden',
    body: 'Absolutely brilliant from start to finish. John and the team transformed our tired back garden into something we\'re genuinely proud of. They turned up every day on time, kept everything tidy, and the finished patio is stunning.',
    avatar: avatar1,
    name: 'Sarah T., BA2',
    job: 'Garden Landscaping',
    platformLogo: googleLogo,
    platformAlt: 'Google Reviews',
    platformClass: 'google',
  },
  {
    headline: 'Several neighbours asked for their number',
    body: 'We had a full Indian sandstone patio laid and new fencing installed. The team were professional throughout, no hidden costs, and the quality of the work is exceptional.',
    avatar: avatar2,
    name: 'Mark H., BA1',
    job: 'Patio & Paving',
    platformLogo: checkatradeLogo,
    platformAlt: 'Checkatrade',
    platformClass: 'checkatrade',
  },
  {
    headline: 'Left the site spotless every evening',
    body: 'Majestic did our block paving driveway and the result is incredible. They handled everything from groundwork to drainage. Competitive price, no fuss.',
    avatar: avatar3,
    name: 'David R., BS31',
    job: 'Driveway',
    platformLogo: googleLogo,
    platformAlt: 'Google Reviews',
    platformClass: 'google',
  },
  {
    headline: 'Will use again without question',
    body: 'Had a completely overgrown garden cleared and artificial grass laid. The transformation in two days was unbelievable. Friendly team, fair price.',
    avatar: avatar4,
    name: 'Emma W., BA2',
    job: 'Garden Clearance',
    platformLogo: googleLogo,
    platformAlt: 'Google Reviews',
    platformClass: 'google',
  },
];

const aboutSlides = [
  { src: galleryPatio, alt: 'Stone patio completed in Bath' },
  { src: galleryDriveway, alt: 'Block paving driveway in Bath' },
  { src: galleryGrass, alt: 'New lawn and borders in Bath' },
  { src: galleryFencing, alt: 'Timber fencing in Bath' },
  { src: galleryDecking, alt: 'Composite decking in Bath' },
  { src: galleryGarden, alt: 'Garden transformation in Bath' },
];

const faqs = [
  {
    question: 'Do you charge for quotes or consultations?',
    answer: 'No. We provide free, no-obligation quotes for all landscaping work. We will visit your property, discuss your ideas, and give you a detailed written estimate at no cost.',
  },
  {
    question: 'What areas do you cover?',
    answer: 'We cover Bath and all BA postcode areas, including Keynsham, Radstock, and surrounding villages. If you\'re unsure whether we cover your area, give us a call.',
  },
  {
    question: 'Will there be any hidden costs?',
    answer: 'Never. The written quote we give you is the final price. We don\'t add call-out fees, admin charges, or surprise extras. What we quote is what you pay.',
  },
  {
    question: 'Do you use sub-contractors?',
    answer: 'No. Every project is carried out by our own trained team. We don\'t sub-contract work to third parties, so you always know who is working on your property.',
  },
  {
    question: 'How long does a typical landscaping project take?',
    answer: 'It depends on the scope of the work. A simple patio might take 3 to 5 days, while a full garden transformation could take 2 to 3 weeks. We give you a clear timeline before any work starts.',
  },
  {
    question: 'Do you handle garden waste removal?',
    answer: 'Yes. All waste is removed from your property and disposed of responsibly. We leave your site clean and tidy at the end of every working day.',
  },
];

const platforms = [
  { logo: googleLogo, alt: 'Google Reviews logo', rating: '4.7', count: 20, suffix: '', slug: 'google' },
  { logo: facebookLogo, alt: 'Facebook Reviews logo', rating: '5.0', count: 11, suffix: '', slug: 'facebook' },
  { logo: checkatradeLogo, alt: 'Checkatrade logo', rating: '10/10', count: 29, suffix: '+', slug: 'checkatrade' },
];
---

<LandscapingV2Layout
  title="Trusted Landscaping Experts Bath | Majestic Services"
  description="Professional landscaping services in Bath. Patios, driveways, fencing, garden design and more. Free quotes, no hidden fees. Call 01225 985713."
>

<!-- ============================================
     SECTION 1: STICKY HEADER
     ============================================ -->
<header class="ls2-header">
  <div class="ls2-header__inner">
    <a class="ls2-header__logo" href="#">
      <Image src={logo} alt="Majestic Services logo" width={376} quality={100} format="png" loading="eager" />
    </a>

    <div class="ls2-header__right">
      <div class="ls2-header__badges">
        <div class="ls2-header__badge ls2-header__badge--reviews">
          <Image src={reviewIcons} alt="Review platform logos" width={400} quality={100} loading="eager" />
          <div class="ls2-header__badge-text">
            <span class="ls2-header__badge-score"><strong>Rated 4.9 Based On</strong></span>
            <span class="ls2-header__badge-detail">97+ Verified Reviews</span>
          </div>
        </div>

        <div class="ls2-header__badge-divider"></div>

        <div class="ls2-header__badge ls2-header__badge--checkatrade">
          <Image src={checkatradeLogo} alt="Checkatrade approved" width={400} quality={100} format="png" loading="eager" />
          <div class="ls2-header__badge-text">
            <span class="ls2-header__badge-score"><strong>Rated 10/10</strong> (40+ Reviews)</span>
          </div>
        </div>
      </div>

      <div class="ls2-header__phone">
        <div>
          <div class="ls2-header__phone-number"><a href={phoneHref}>{phone}</a></div>
          <div class="ls2-header__phone-label">Call Us For a Free Quote</div>
        </div>
      </div>
    </div>
  </div>
</header>

<!-- ============================================
     SECTION 2: TRUST BAR
     ============================================ -->
<div class="ls2-trust-strip">
  <div class="ls2-trust-strip__inner ls2-container">
    <span class="ls2-trust-strip__item">
      <span class="ls2-trust-strip__icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z" clip-rule="evenodd"/></svg></span>
      5/5 Rated Business
    </span>
    <span class="ls2-trust-strip__item">
      <span class="ls2-trust-strip__icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M8.603 3.799A4.49 4.49 0 0 1 12 2.25c1.357 0 2.573.6 3.397 1.549a4.49 4.49 0 0 1 3.498 1.307 4.491 4.491 0 0 1 1.307 3.497A4.49 4.49 0 0 1 21.75 12a4.49 4.49 0 0 1-1.549 3.397 4.491 4.491 0 0 1-1.307 3.497 4.491 4.491 0 0 1-3.497 1.307A4.49 4.49 0 0 1 12 21.75a4.49 4.49 0 0 1-3.397-1.549 4.49 4.49 0 0 1-3.498-1.306 4.491 4.491 0 0 1-1.307-3.498A4.49 4.49 0 0 1 2.25 12c0-1.357.6-2.573 1.549-3.397a4.49 4.49 0 0 1 1.307-3.497 4.49 4.49 0 0 1 3.497-1.307Zm7.007 6.387a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd"/></svg></span>
      All Work Guaranteed
    </span>
    <span class="ls2-trust-strip__item">
      <span class="ls2-trust-strip__icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25ZM9.763 9.51a2.25 2.25 0 0 1 3.828-1.351.75.75 0 0 0 1.06-1.06 3.75 3.75 0 0 0-6.38 2.252c-.033.307 0 .595.032.822l.154 1.077H8.25a.75.75 0 0 0 0 1.5h.421l.138.964a3.75 3.75 0 0 1-.358 2.208l-.122.242a.75.75 0 0 0 .908 1.047l1.539-.512a1.5 1.5 0 0 1 .948 0l.655.218a3 3 0 0 0 2.29-.163l.666-.333a.75.75 0 1 0-.67-1.342l-.667.333a1.5 1.5 0 0 1-1.145.082l-.654-.218a3 3 0 0 0-1.898 0l-.06.02a5.25 5.25 0 0 0 .053-1.794l-.108-.752H12a.75.75 0 0 0 0-1.5H9.972l-.184-1.29a1.863 1.863 0 0 1-.025-.45Z" clip-rule="evenodd"/></svg></span>
      No Hidden Fees
    </span>
    <span class="ls2-trust-strip__item">
      <span class="ls2-trust-strip__icon"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M9 1.5H5.625c-1.036 0-1.875.84-1.875 1.875v17.25c0 1.035.84 1.875 1.875 1.875h12.75c1.035 0 1.875-.84 1.875-1.875V12.75A3.75 3.75 0 0 0 16.5 9h-1.875a1.875 1.875 0 0 1-1.875-1.875V5.25A3.75 3.75 0 0 0 9 1.5Zm6.61 10.936a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 14.47a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z" clip-rule="evenodd"/><path d="M12.971 1.816A5.23 5.23 0 0 1 14.25 5.25v1.875c0 .207.168.375.375.375H16.5a5.23 5.23 0 0 1 3.434 1.279 9.768 9.768 0 0 0-6.963-6.963Z"/></svg></span>
      Free Quotes
    </span>
  </div>
</div>

<!-- ============================================
     SECTION 3: HERO (compact, centered, NO form)
     ============================================ -->
<section class="ls2-hero ls2-hero--compact">
  <Image
    src={heroImg}
    alt="Beautifully landscaped garden in Bath"
    class="ls2-hero__bg"
    widths={[600, 900, 1200]}
    loading="eager"
  />
  <div class="ls2-hero__inner ls2-hero__inner--compact">
    <div class="ls2-hero__content ls2-hero__content--compact">
      <div class="ls2-hero__rating">
        <span class="ls2-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        <span>Rated 5/5 by customers</span>
      </div>
      <h1 class="ls2-hero__title">Trusted Landscaping Experts Bath</h1>
      <p class="ls2-hero__subtitle">Qualified landscapers with years of hands-on experience. We design it right, quote it fair, and guarantee every job.</p>
    </div>
  </div>
  <a href="#quote-form" class="ls2-hero__scroll-arrow" aria-label="Scroll to quote form">
    <img src="/scroll-arrow.gif" alt="" width="64" height="64" />
  </a>
</section>

<!-- ============================================
     SECTION 4: QUOTE FORM (two-step tiles)
     ============================================ -->
<section class="ls2-form-section" id="quote-form">
  <div class="ls2-form-section__inner ls2-container">
    <div class="ls2-form-section__header">
      <h2 class="ls2-form-section__title">Get a FREE Quote For Your Landscaping Job</h2>
      <p class="ls2-form-section__subtitle">What type of landscaping service do you need?</p>
    </div>

    <div class="ls2-form-step" id="ls2-form-step-1">
      <div class="ls2-form-tiles">
        <label class="ls2-form-tile">
          <input type="radio" name="ls2-service" value="Patios & Paving" />
          <span class="ls2-form-tile__radio"></span>
          <span class="ls2-form-tile__label">Patios & Paving</span>
        </label>
        <label class="ls2-form-tile">
          <input type="radio" name="ls2-service" value="Driveways & Block Paving" />
          <span class="ls2-form-tile__radio"></span>
          <span class="ls2-form-tile__label">Driveways & Block Paving</span>
        </label>
        <label class="ls2-form-tile">
          <input type="radio" name="ls2-service" value="Fencing & Decking" />
          <span class="ls2-form-tile__radio"></span>
          <span class="ls2-form-tile__label">Fencing & Decking</span>
        </label>
        <label class="ls2-form-tile">
          <input type="radio" name="ls2-service" value="Other Landscaping" />
          <span class="ls2-form-tile__radio"></span>
          <span class="ls2-form-tile__label">Other Landscaping</span>
        </label>
      </div>

      <div class="ls2-form-progress">
        <div class="ls2-form-progress__bar">
          <div class="ls2-form-progress__fill" id="ls2-progress-fill"></div>
        </div>
      </div>
    </div>

    <div class="ls2-form-step ls2-form-step--hidden" id="ls2-form-step-2">
      <form action="#" class="ls2-form-fields">
        <!-- Form action TBC -->
        <input type="hidden" name="service" id="ls2-hidden-service" value="" />
        <div class="ls2-form-field">
          <input type="text" name="name" placeholder="Your Name" required />
        </div>
        <div class="ls2-form-field">
          <input type="email" name="email" placeholder="Email Address" required />
        </div>
        <div class="ls2-form-field">
          <input type="tel" name="phone" placeholder="Phone Number" required />
        </div>
        <div class="ls2-form-field">
          <input type="text" name="postcode" placeholder="Postcode" required />
        </div>
        <button type="submit" class="ls2-btn ls2-btn--action ls2-form-submit">Get My Free Quote</button>
      </form>
    </div>

    <p class="ls2-form-section__or">Or call us now: <a href={phoneHref}><strong>{phone}</strong></a></p>
  </div>
</section>

<!-- ============================================
     SECTION 5: ACCREDITATION LOGOS BAR
     ============================================ -->
<section class="ls2-accreditations">
  <div class="ls2-accreditations__inner ls2-container">
    {accreditationLogos.map((item) => (
      <div class="ls2-accreditations__item">
        <Image src={item.src} alt={item.alt} width={400} quality={100} loading="lazy" />
      </div>
    ))}
  </div>
</section>

<!-- ============================================
     SECTION 6: SERVICES GRID
     ============================================ -->
<section class="ls2-section">
  <div class="ls2-container">
    <div class="ls2-section__header">
      <h2>Professional Landscaping Services</h2>
      <p>We handle everything from garden design to complete outdoor transformations. Every job includes a free survey and a fixed written quote.</p>
    </div>
    <div class="ls2-services-grid">
      {services.map((s) => (
        <div class="ls2-service-card">
          <Image src={s.img} alt={s.alt} widths={[300, 450]} loading="lazy" />
          <div class="ls2-service-card__overlay"></div>
          <div class="ls2-service-card__label">{s.label}</div>
        </div>
      ))}
    </div>
    <div class="ls2-mid-cta">
      <a href="#quote-form" class="ls2-btn ls2-btn--action">Get Your Free Landscaping Quote</a>
      <span class="ls2-mid-cta__phone">Or call us now: <a href={phoneHref}>{phone}</a></span>
    </div>
  </div>
</section>

<!-- ============================================
     SECTION 7: ABOUT SECTION
     ============================================ -->
<section class="ls2-section ls2-about-section">
  <div class="ls2-container">
    <div class="ls2-section__header">
      <h2>Welcome to Majestic Services LTD</h2>
    </div>
    <div class="ls2-about-split">
      <div class="ls2-about-gallery">
        <div class="ls2-about-gallery__track">
          {aboutSlides.map((slide, i) => (
            <div class={`ls2-about-gallery__slide ${i === 0 ? 'active' : ''}`} data-slide={i}>
              <Image src={slide.src} alt={slide.alt} widths={[400, 600]} loading="lazy" />
            </div>
          ))}
        </div>
        <button class="ls2-about-gallery__arrow ls2-about-gallery__arrow--prev" aria-label="Previous slide">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        <button class="ls2-about-gallery__arrow ls2-about-gallery__arrow--next" aria-label="Next slide">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
        <div class="ls2-about-gallery__dots">
          {aboutSlides.map((_, i) => (
            <button class={`ls2-about-gallery__dot ${i === 0 ? 'active' : ''}`} data-dot={i} aria-label={`Show image ${i + 1}`} />
          ))}
        </div>
      </div>
      <div class="ls2-about-split__content">
        <p>Majestic Services are landscaping experts based in Bath. We're a fully certified, family-run business with years of experience delivering quality workmanship and a personal service.</p>
        <p>No hidden charges. No call-out fees. Just clear, written quotes, completely FREE, so you can plan with confidence.</p>
        <p>Call Majestic Services at <a href={phoneHref} class="ls2-about-split__phone">{phone}</a> for a free quote or a chat about your landscaping needs. We're always here to offer advice and support!</p>
      </div>
    </div>
    <div class="ls2-mid-cta">
      <a href="#quote-form" class="ls2-btn ls2-btn--action">Get Your Free Landscaping Quote</a>
    </div>
  </div>
</section>

<!-- ============================================
     SECTION 8: REVIEWS
     ============================================ -->
<section class="ls2-section" style="padding: 28px 0;">
  <div class="ls2-container">
    <div class="ls2-section__header">
      <h2>What Our Customers Say</h2>
      <p>Real reviews from real homeowners across Bath</p>
    </div>
    <div class="ls2-testimonials-grid">
      {testimonials.map((t, i) => (
        <div class="ls2-testimonial-card" data-slide={i}>
          <div class="ls2-testimonial-card__quote-mark">&ldquo;</div>
          <div class="ls2-testimonial-card__headline">{t.headline}</div>
          <p class="ls2-testimonial-card__body">{t.body}</p>
          <div class="ls2-testimonial-card__footer">
            <div class="ls2-testimonial-card__author">
              <Image src={t.avatar} alt={t.name} width={80} quality={80} class="ls2-testimonial-card__avatar" />
              <div>
                <div class="ls2-testimonial-card__name">{t.name}</div>
                <div class="ls2-testimonial-card__job">{t.job}</div>
              </div>
            </div>
            <div class="ls2-testimonial-card__rating">
              <div class="ls2-testimonial-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
              <Image src={t.platformLogo} alt={t.platformAlt} width={200} quality={100} class={`ls2-testimonial-card__platform-logo ls2-testimonial-card__platform-logo--${t.platformClass}`} />
            </div>
          </div>
        </div>
      ))}
    </div>
    <div class="ls2-testimonials-dots">
      {testimonials.map((_, i) => (
        <button class={`ls2-testimonials-dot ${i === 0 ? 'active' : ''}`} data-dot={i} aria-label={`Show review ${i + 1}`} />
      ))}
    </div>
  </div>
</section>

<!-- ============================================
     SECTION 9: PLATFORM RATINGS
     ============================================ -->
<div class="ls2-platforms">
  <div class="ls2-platforms__inner ls2-container">
    {platforms.map((p) => (
      <div class={`ls2-platform ls2-platform--${p.slug}`}>
        <Image src={p.logo} alt={p.alt} width={400} quality={100} loading="lazy" class="ls2-platform__logo-img" />
        <div class="ls2-platform__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <div class="ls2-platform__meta">
          Rated <strong>{p.rating}</strong> from <strong><span class="ls2-counter" data-target={p.count} data-suffix={p.suffix}>0</span>{p.suffix}</strong> reviews
        </div>
      </div>
    ))}
  </div>
</div>

<!-- ============================================
     SECTION 10: WHY CHOOSE US
     ============================================ -->
<section class="ls2-section ls2-section--off-white">
  <div class="ls2-container">
    <div class="ls2-section__header">
      <h2>Why Bath Trusts Majestic Services</h2>
    </div>
    <div class="ls2-usp-grid">
      <div class="ls2-usp-item">
        <div class="ls2-usp-item__icon">
