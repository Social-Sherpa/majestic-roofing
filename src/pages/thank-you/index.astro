---
import RoofingLayout from '../../layouts/RoofingLayout.astro';
import Header from '../../components/roofing/Header.astro';
import Footer from '../../components/roofing/Footer.astro';

const phone = '01225 985713';
const phoneHref = `tel:${phone.replace(/\s/g, '')}`;
---

<RoofingLayout
  title="Thank You | Majestic Roofing"
  description="Thank you for your enquiry. We'll be in touch shortly."
>
  <Header phone={phone} />
  <section class="thank-you">
    <div class="container">
      <div class="thank-you__icon">&#10003;</div>
      <h1>Thank You!</h1>
      <p>Your quote request has been received. We'll get back to you within a few hours.</p>
      <p class="thank-you__phone">Or call us now: <a href={phoneHref}>{phone}</a></p>
    </div>
  </section>
  <Footer phone={phone} />
</RoofingLayout>
