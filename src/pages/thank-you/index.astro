---
import LandingLayout from '../../layouts/LandingLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

import logo from '../../assets/brand/Majestic property services 500x200.png';
import reviewIcons from '../../assets/logos/review-platform-icons.webp';
import checkatradeLogo from '../../assets/logos/checkatrade-approved-roofer.png';

const phone = '01225 985713';
const phoneHref = `tel:${phone.replace(/\s/g, '')}`;
---

<LandingLayout
  title="Thank You | Majestic Roofing"
  description="Thank you for your enquiry. We'll be in touch shortly."
>
  <Header
    logo={logo}
    logoAlt="Majestic Roofing logo"
    reviewBadge={reviewIcons}
    checkatradeLogo={checkatradeLogo}
    phone={phone}
  />
  <section class="thank-you">
    <div class="container">
      <div class="thank-you__icon">&#10003;</div>
      <h1>Thank You!</h1>
      <p>Your quote request has been received. We'll get back to you within a few hours.</p>
      <p class="thank-you__phone">Or call us now: <a href={phoneHref}>{phone}</a></p>
    </div>
  </section>
  <Footer phone={phone} />
</LandingLayout>
