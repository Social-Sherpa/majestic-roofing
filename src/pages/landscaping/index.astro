<style>
  /* ===== ANNOUNCEMENT BAR ===== */
  .announcement-bar {
    background: var(--ls-brand);
    color: #ffffff;
    padding: 10px 0;
    font-size: 0.85rem;
  }

  .announcement-bar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  .announcement-bar__message a {
    color: #ffffff;
    font-weight: 600;
    text-decoration: underline;
  }

  .announcement-bar__ticks {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }

  .announcement-bar__tick {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8rem;
    white-space: nowrap;
  }

  .announcement-bar__tick svg {
    color: var(--ls-action);
  }

  @media (max-width: 768px) {
    .announcement-bar__ticks {
      display: none;
    }

    .announcement-bar__inner {
      justify-content: center;
      text-align: center;
    }
  }

  /* ===== HEADER ===== */
  .ls-header {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: #ffffff;
    border-bottom: 1px solid var(--ls-border);
    padding: 0;
  }

  .ls-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
    gap: 24px;
  }

  .ls-header__logo img {
    height: 48px;
    width: auto;
  }

  .ls-header__nav {
    display: flex;
    gap: 28px;
  }

  .ls-header__nav a {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    color: var(--ls-black);
    transition: color 0.2s;
    white-space: nowrap;
  }

  .ls-header__nav a:hover {
    color: var(--ls-action);
  }

  .ls-header__actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ls-header__cta {
    padding: 10px 24px;
    font-size: 0.9rem;
  }

  .ls-header__phone-btn {
    display: none;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--ls-action);
    color: #ffffff;
  }

  @media (max-width: 768px) {
    .ls-header__nav {
      display: none;
    }

    .ls-header__cta {
      display: none;
    }

    .ls-header__phone-btn {
      display: flex;
    }
  }

  /* ===== HERO ===== */
  .ls-hero {
    position: relative;
    padding: 80px 0;
    min-height: 600px;
    display: flex;
    align-items: center;
    color: #ffffff;
  }

  .ls-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .ls-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ls-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
  }

  .ls-hero__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 48px;
    align-items: center;
  }

  .ls-hero__pre {
    display: inline-block;
    color: var(--ls-action);
    font-weight: 600;
    font-size: 1rem;
    margin-bottom: 12px;
    letter-spacing: 0.5px;
  }

  .ls-hero h1 {
    color: #ffffff;
    margin-bottom: 16px;
    font-size: 2.25rem;
    line-height: 1.2;
  }

  .ls-hero__subtitle {
    font-size: 1.05rem;
    line-height: 1.6;
    margin-bottom: 24px;
    opacity: 0.9;
  }

  .ls-hero__ticks {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px 24px;
    margin-bottom: 28px;
  }

  .ls-hero__cta-row {
    margin-bottom: 12px;
  }

  .ls-hero__subtext {
    font-size: 0.85rem;
    opacity: 0.7;
  }

  /* Hero Form */
  .ls-hero-form {
    background: #ffffff;
    border-radius: var(--ls-radius-lg);
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    color: var(--ls-black);
  }

  .ls-hero-form__tabs {
    display: flex;
  }

  .ls-hero-form__tab {
    flex: 1;
    padding: 14px;
    font-size: 0.9rem;
    font-weight: 600;
    background: var(--ls-light-grey);
    border: none;
    color: var(--ls-text-secondary);
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }

  .ls-hero-form__tab.active {
    background: #ffffff;
    color: var(--ls-brand);
  }

  .ls-hero-form__form {
    padding: 24px;
  }

  .ls-hero-form__step {
    display: none;
  }

  .ls-hero-form__step.active {
    display: block;
  }

  .ls-hero-form__step h3 {
    margin-bottom: 20px;
    font-size: 1.2rem;
    text-align: center;
  }

  .ls-form-group__label {
    font-size: 0.85rem;
    font-weight: 500;
    margin-bottom: 10px;
  }

  .ls-radio-group {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .ls-radio {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.9rem;
    cursor: pointer;
  }

  .ls-radio input {
    accent-color: var(--ls-action);
  }

  .ls-hero-form__back {
    display: block;
    margin: 12px auto 0;
    background: none;
    border: none;
    color: var(--ls-text-secondary);
    font-size: 0.85rem;
    text-decoration: underline;
    cursor: pointer;
  }

  @media (max-width: 960px) {
    .ls-hero__grid {
      grid-template-columns: 1fr;
      max-width: 560px;
    }

    .ls-hero__ticks {
      display: none;
    }

    .ls-hero__cta-row {
      display: none;
    }

    .ls-hero__subtext {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .ls-hero {
      padding: 48px 0;
    }
  }

  /* ===== REVIEW STRIP ===== */
  .ls-review-strip {
    padding: 20px 0;
    border-bottom: 1px solid var(--ls-border);
  }

  .ls-review-strip__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .ls-review-strip__label {
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--ls-black);
  }

  .ls-review-strip__score {
    font-size: 0.95rem;
    color: var(--ls-text-secondary);
  }

  .ls-review-strip__logos {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .ls-review-strip__logos img {
    height: 24px;
    width: auto;
    object-fit: contain;
  }

  @media (max-width: 480px) {
    .ls-review-strip__logos {
      display: none;
    }
  }

  /* ===== ABOUT ===== */
  .ls-about__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }

  .ls-about__image img {
    border-radius: var(--ls-radius-lg);
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .ls-about__content h2 {
    margin-bottom: 20px;
    font-size: 1.75rem;
  }

  .ls-about__content p {
    color: var(--ls-text-secondary);
    margin-bottom: 16px;
    line-height: 1.7;
  }

  .ls-about__ticks {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 24px;
  }

  @media (max-width: 768px) {
    .ls-about__grid {
      grid-template-columns: 1fr;
    }

    .ls-about__ticks {
      grid-template-columns: 1fr;
    }
  }

  /* ===== REPUTATION ===== */
