---
import LandscapingLayout from '../../layouts/LandscapingLayout.astro';
import { Image } from 'astro:assets';

import heroImg from '../../assets/images/landscaping/hero-landscaped-garden-bath.png';
import galleryPatio from '../../assets/images/landscaping/gallery-stone-patio-bath.png';
import galleryDecking from '../../assets/images/landscaping/gallery-composite-decking.png';
import galleryFencing from '../../assets/images/landscaping/gallery-timber-fencing.png';
import galleryTransformation from '../../assets/images/landscaping/gallery-garden-transformation.png';
import logo from '../../assets/brand/Majestic property services 500x200.png';

import googleLogo from '../../assets/logos/google-colorful-logo.png';
import facebookLogo from '../../assets/logos/Facebook.png';
import checkatradeBadge from '../../assets/logos/Checkatrade-badge.png';

// Images that don't exist yet use fallbacks
// When team-laying-paving-bath.png, gallery-block-paving-driveway.png, and
// gallery-new-lawn-borders.png are added to assets/images/landscaping/, import them above
// and update the references below.

const phone = '01225 985713';
const phoneTel = 'tel:01225985713';

const services = [
  'Garden Design & Landscaping',
  'Patio & Paving',
  'Driveway & Block Paving',
  'Fencing & Decking',
  'Artificial Grass & Lawns',
  'Brickwork & Walls',
  'Garden Clearance',
  'Pressure Washing',
  'Other',
];

const propertyTypes = [
  'Detached',
  'Semi-Detached',
  'Terraced',
  'Bungalow',
  'Flat',
  'Commercial',
];

const faqs = [
  {
    question: 'How long have you been in the landscaping industry?',
    answer: 'We have years of hands-on experience transforming gardens across Bath and the surrounding areas. Our team has worked on everything from small courtyard makeovers to full garden redesigns, driveways, patios, and commercial landscaping projects.',
  },
  {
    question: 'Where are you based and what areas do you cover?',
    answer: 'We are based in Bath and cover all surrounding areas including BA1, BA2, BA3, BS31, and beyond. If you are unsure whether we cover your area, give us a call on 01225 985713 and we will let you know.',
  },
  {
    question: 'Will there be any hidden costs?',
    answer: 'Absolutely not. We provide a detailed, written quote before any work begins. The price we quote is the price you pay. No surprises, no hidden extras, no call-out charges.',
  },
  {
    question: 'Do you use sub-contractors?',
    answer: 'No. All work is carried out by our own trained team. We never sub-contract your job out. That means consistent quality, clear communication, and full accountability from start to finish.',
  },
  {
    question: 'Do you specialise in any particular landscaping service?',
    answer: 'We handle the full range of landscaping and garden services, from patios and paving to fencing, decking, driveways, artificial grass, garden clearance, and complete garden redesigns. Whatever you need, we have the skills and experience to deliver it to a high standard.',
  },
  {
    question: 'Will I have to pay for a consultation or quote?',
    answer: 'No. Every consultation and quote is completely free with no obligation. We will visit your property, discuss your ideas, assess the work needed, and provide a clear written quote at no cost to you.',
  },
];

const reviews = [
  {
    stars: 5,
    title: 'Garden Landscaping',
    body: 'Absolutely brilliant from start to finish. The team were polite, tidy, and really knew their stuff. Our garden looks completely different now. They took the time to understand what we wanted and delivered exactly that. Would recommend to anyone.',
    name: 'Sarah T.',
    location: 'BA2',
  },
  {
    stars: 5,
    title: 'Patio & Paving',
    body: 'We had a full Indian sandstone patio laid and the finish is outstanding. The team worked through some difficult weather and still kept to schedule. Really impressed with the attention to detail and the cleanup afterwards.',
    name: 'Mark H.',
    location: 'BA1',
  },
  {
    stars: 5,
    title: 'Driveway',
    body: 'Majestic did our block paving driveway and we could not be happier. From the initial visit to the final sweep-up, everything was professional and on time. The driveway looks fantastic and has completely changed the front of our house.',
    name: 'David & Carol R.',
    location: 'BS31',
  },
  {
    stars: 5,
    title: 'Garden Clearance & Artificial Grass',
    body: 'Had a completely overgrown garden cleared and artificial grass put down. The transformation is incredible. The team worked hard and were friendly throughout. It is so low maintenance now and looks great all year round.',
    name: 'Emma W.',
    location: 'BA2',
  },
  {
    stars: 5,
    title: 'Full Garden Redesign',
    body: 'From the initial quote to the final tidy-up, everything was handled professionally. They redesigned our entire back garden with new paving, raised beds, fencing, and lighting. It has completely transformed how we use the space.',
    name: 'Paul & Janet M.',
    location: 'BA3',
  },
  {
    stars: 5,
    title: 'Fencing & Decking',
    body: 'New composite decking and close-board fencing installed. The quality of workmanship is excellent. They even helped us choose the right materials for our budget. Very happy with the result and the whole experience.',
    name: 'Richard O.',
    location: 'BA3',
  },
];

const galleryImages = [
  { src: galleryPatio, alt: 'Indian sandstone patio installation in Bath' },
  { src: galleryFencing, alt: 'Close-board timber fencing in Bath' },
  { src: galleryDecking, alt: 'Composite decking installation in Bath' },
  { src: galleryTransformation, alt: 'Full garden transformation in Bath' },
  // Add gallery-block-paving-driveway.png and gallery-new-lawn-borders.png when available
];
---

<LandscapingLayout
  title="Trusted Landscapers Bath | Majestic Property Services"
  description="Expert landscaping and garden transformation services in Bath. Free quotes, no hidden fees. Patios, driveways, fencing, decking, and more. Call 01225 985713."
>

<!-- ===== 1. ANNOUNCEMENT BAR ===== -->
<div class="announcement-bar">
  <div class="ls-container">
    <div class="announcement-bar__inner">
      <span class="announcement-bar__message">
        We'll price your landscaping job for FREE! Simply call <a href={phoneTel}>{phone}</a>
      </span>
      <div class="announcement-bar__ticks">
        <span class="announcement-bar__tick">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
          Years of Experience
        </span>
        <span class="announcement-bar__tick">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
          All Work 100% Guaranteed
        </span>
        <span class="announcement-bar__tick">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
          Fully Insured
        </span>
        <span class="announcement-bar__tick">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
          No Call Out Charges
        </span>
      </div>
    </div>
  </div>
</div>

<!-- ===== 2. STICKY HEADER ===== -->
<header class="ls-header" id="ls-header">
  <div class="ls-container">
    <div class="ls-header__inner">
      <a href="/landscaping/" class="ls-header__logo">
        <Image src={logo} alt="Majestic Property Services" width={180} height={72} />
      </a>
      <nav class="ls-header__nav">
        <a href="#home">HOME</a>
        <a href="#why-us">WHY US?</a>
        <a href="#services">SERVICES</a>
        <a href="#reviews">REVIEWS</a>
        <a href="#our-work">OUR WORK</a>
        <a href="#faq">FAQ</a>
      </nav>
      <div class="ls-header__actions">
        <a href="#quote-form" class="ls-btn ls-btn--green ls-header__cta">Get a FREE Quote</a>
        <a href={phoneTel} class="ls-header__phone-btn" aria-label="Call us">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22"><path fill-rule="evenodd" d="M1.5 4.5a3 3 0 013-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 01-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 006.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 011.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 01-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5z" clip-rule="evenodd" /></svg>
        </a>
      </div>
    </div>
  </div>
</header>

<!-- ===== 3. HERO SECTION ===== -->
<section class="ls-hero" id="home">
  <div class="ls-hero__bg">
    <Image src={heroImg} alt="Beautifully landscaped garden in Bath" width={1920} height={1080} loading="eager" />
    <div class="ls-hero__overlay"></div>
  </div>
  <div class="ls-container">
    <div class="ls-hero__grid">
      <div class="ls-hero__content">
        <span class="ls-hero__pre">Bath &amp; Surrounding Areas</span>
        <h1>Bath's Expert Landscaping &amp; Garden Transformation Specialists</h1>
        <p class="ls-hero__subtitle">From garden redesigns to patios, driveways, fencing, and decking. We handle every aspect of your outdoor space with care and craftsmanship.</p>
        <div class="ls-hero__ticks">
          <span class="ls-tick ls-tick--white">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
            Free, no-obligation quotes
          </span>
          <span class="ls-tick ls-tick--white">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
            All work fully guaranteed
          </span>
          <span class="ls-tick ls-tick--white">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
            Experienced, local team
          </span>
          <span class="ls-tick ls-tick--white">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
            No hidden fees
          </span>
        </div>
        <div class="ls-hero__cta-row">
          <a href={phoneTel} class="ls-btn ls-btn--green">Call {phone}</a>
        </div>
        <p class="ls-hero__subtext">Or fill in the form to get your free quote online</p>
      </div>

      <!-- Hero Quote Form -->
      <div class="ls-hero-form" id="quote-form">
        <div class="ls-hero-form__tabs">
          <button class="ls-hero-form__tab active" data-step="1">Step 1</button>
          <button class="ls-hero-form__tab" data-step="2">Step 2</button>
        </div>
        <form action="#" method="POST" class="ls-hero-form__form">
          <!-- Connect to CRM/webhook endpoint -->
          <div class="ls-hero-form__step active" data-form-step="1">
            <h3>Get Your FREE Quote</h3>
            <div class="ls-form-group">
              <select name="service" class="ls-input" required>
                <option value="" disabled selected>What Landscaping Service Do You Need?</option>
                {services.map(s => <option value={s}>{s}</option>)}
              </select>
            </div>
            <div class="ls-form-group">
              <select name="property_type" class="ls-input" required>
                <option value="" disabled selected>What Type of Property Is This?</option>
                {propertyTypes.map(p => <option value={p}>{p}</option>)}
              </select>
            </div>
            <div class="ls-form-group">
              <p class="ls-form-group__label">How Soon Do You Need Help?</p>
              <div class="ls-radio-group">
                <label class="ls-radio"><input type="radio" name="urgency" value="ASAP" required /> ASAP</label>
                <label class="ls-radio"><input type="radio" name="urgency" value="This Month" /> This Month</label>
                <label class="ls-radio"><input type="radio" name="urgency" value="Next 2-3 Months" /> Next 2-3 Months</label>
              </div>
            </div>
            <button type="button" class="ls-btn ls-btn--green ls-btn--full" id="hero-form-next">Continue to Step 2</button>
          </div>
          <div class="ls-hero-form__step" data-form-step="2">
            <h3>Your Details</h3>
            <div class="ls-form-group">
              <input type="text" name="name" class="ls-input" placeholder="Your Name" required />
            </div>
            <div class="ls-form-group">
              <input type="email" name="email" class="ls-input" placeholder="Email Address" required />
            </div>
            <div class="ls-form-group">
              <input type="tel" name="phone" class="ls-input" placeholder="Phone Number" required />
            </div>
            <div class="ls-form-group">
              <input type="text" name="postcode" class="ls-input" placeholder="Postcode" required />
            </div>
            <button type="submit" class="ls-btn ls-btn--green ls-btn--full">Get My FREE Quote</button>
            <button type="button" class="ls-hero-form__back" id="hero-form-back">Back to Step 1</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<!-- ===== 4. REVIEW STRIP ===== -->
<section class="ls-review-strip">
  <div class="ls-container">
    <div class="ls-review-strip__inner">
      <span class="ls-review-strip__label">Excellent</span>
      <div class="ls-stars">
        {[1,2,3,4,5].map(() => (
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" /></svg>
        ))}
      </div>
      <span class="ls-review-strip__score">5/5 based on 97+ reviews</span>
      <div class="ls-review-strip__logos">
        <Image src={googleLogo} alt="Google Reviews" width={80} height={28} />
        <Image src={facebookLogo} alt="Facebook Reviews" width={80} height={28} />
        <Image src={checkatradeBadge} alt="Checkatrade" width={80} height={28} />
      </div>
    </div>
  </div>
</section>

<!-- ===== 5. WELCOME / ABOUT SECTION ===== -->
<section class="ls-about ls-section" id="why-us">
  <div class="ls-container">
    <div class="ls-about__grid">
      <div class="ls-about__image">
        <Image src={heroImg} alt="Landscaping work in Bath" width={600} height={450} />
      </div>
      <div class="ls-about__content">
        <h2>Are You Looking for a Trusted Landscaper in Bath? Speak to Majestic!</h2>
        <p>We are a local landscaping team based in Bath, delivering high-quality garden transformations across the city and surrounding areas. Whether you need a new patio, a complete garden redesign, or a driveway that transforms the front of your home, we handle it all from start to finish.</p>
        <p>Every quote is free and every project is completed by our own experienced team. No sub-contractors, no hidden charges, no surprises. Just honest, reliable work you can count on.</p>
        <div class="ls-about__ticks">
          <span class="ls-tick ls-tick--green">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
            Free, no-obligation quotes
          </span>
          <span class="ls-tick ls-tick--green">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
            All work 100% guaranteed
          </span>
          <span class="ls-tick ls-tick--green">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
            Fully insured
          </span>
          <span class="ls-tick ls-tick--green">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
            No call-out charges
          </span>
          <span class="ls-tick ls-tick--green">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
            Clean, tidy workmanship
          </span>
          <span class="ls-tick ls-tick--green">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
            Experienced local team
          </span>
          <span class="ls-tick ls-tick--green">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
            Rated 5/5 by our customers
          </span>
          <span class="ls-tick ls-tick--green">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
            No sub-contractors
          </span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== 6. OUTSTANDING REPUTATION ===== -->
<section class="ls-reputation ls-section ls-section--grey">
  <div class="ls-container">
    <div class="ls-reputation__content">
      <h2>Outstanding Reputation</h2>
      <p>Our record speaks for itself. With 97+ verified reviews and a 5-star average, our customers consistently praise the quality of our work, the professionalism of our team, and the care we take with every project. We treat every garden as if it were our own.</p>
      <p>We do not rush jobs. Every project gets a proper site visit, a detailed written estimate, and a planned schedule so you know exactly what is happening and when. That attention to detail is why so many of our customers recommend us to friends and family.</p>
    </div>
  </div>
</section>

<!-- ===== 7. SERVICES SECTION ===== -->
<section class="ls-services ls-section" id="services">
  <div class="ls-container">
    <div class="ls-section__header">
      <h2>Services</h2>
      <p>We handle every aspect of your outdoor space</p>
    </div>
    <div class="ls-services__grid">
      <div class="ls-services__col">
        {['Garden Design', 'Landscape Gardening', 'Patios & Paving', 'Driveways & Block Paving', 'Fencing & Decking', 'Artificial Grass & New Lawns'].map(service => (
          <div class="ls-services__item">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="22" height="22"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
            <span>{service}</span>
          </div>
        ))}
      </div>
      <div class="ls-services__col">
        {['Brickwork & Retaining Walls', 'Garden Clearance', 'Pressure Washing', 'Outdoor Lighting', 'Tree & Hedge Work', 'Everything Else!'].map(service => (
          <div class="ls-services__item">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="22" height="22"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
            <span>{service}</span>
          </div>
        ))}
      </div>
    </div>
    <div class="ls-services__cta">
      <a href={phoneTel} class="ls-btn ls-btn--green">Call {phone} for a Free Quote</a>
    </div>
  </div>
</section>

<!-- ===== 8. REVIEWS SECTION ===== -->
